{
  "name": "servidor-monitor-odds",
  "version": "1.0.3",
  "description": "Launcher simples do servidor local do Monitor Odds.",
  "main": "src/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "package": "npm --prefix .. run build && node scripts/write-env-resource.js && electron-builder --win nsis",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "br.monitorodds.servidor",
    "productName": "Servidor Monitor Odds",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "monitor/dist"
      },
      {
        "from": "../node_modules",
        "to": "monitor/node_modules"
      },
      {
        "from": "../package.json",
        "to": "monitor/package.json"
      },
      {
        "from": "build/monitor-env.json",
        "to": "monitor-env.json"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "matsilvaj",
        "repo": "monitor-odds"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Servidor-Monitor-Odds-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
