{
  "name": "monitor-odds",
  "version": "1.0.0",
  "description": "Coletor de odds pre-jogo com persistencia no Supabase.",
  "main": "dist/jobs/sync-watch.js",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "tsx src/jobs/sync-watch.ts",
    "start": "node dist/jobs/sync-watch.js",
    "build": "tsc -p tsconfig.json",
    "db:setup": "tsx src/jobs/db-setup.ts",
    "sync": "npm run sync:all",
    "sync:fixtures": "tsx src/jobs/sync-api-football.ts",
    "sync:odds": "tsx src/jobs/sync-odds.ts",
    "collect": "tsx src/jobs/collect-bookmaker.ts",
    "collect:bookmaker": "tsx src/jobs/collect-bookmaker.ts",
    "sync:all": "tsx src/jobs/sync-all.ts",
    "sync:watch": "tsx src/jobs/sync-watch.ts",
    "sync:watch:worker": "tsx src/jobs/sync-watch-worker.ts",
    "client:dev": "npm --prefix servidor-monitor-odds run dev",
    "client:package": "npm --prefix servidor-monitor-odds run package",
    "client:release": "npm --prefix servidor-monitor-odds run release",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "dotenv": "^17.4.2",
    "got-scraping": "^4.2.1",
    "p-map": "^7.0.4",
    "pg": "^8.20.0",
    "playwright-core": "^1.60.0",
    "tough-cookie": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
