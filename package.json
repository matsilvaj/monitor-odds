{
  "name": "monitor-odds",
  "version": "1.0.0",
  "description": "MVP API para monitoramento simplificado de odds pre-jogo.",
  "main": "dist/index.js",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "node scripts/dev-all.cjs",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "db:setup": "tsx src/jobs/db-setup.ts",
    "sync": "npm run sync:all",
    "sync:fixtures": "tsx src/jobs/sync-api-football.ts",
    "sync:odds": "tsx src/jobs/sync-odds.ts",
    "collect": "tsx src/jobs/collect-bookmaker.ts",
    "collect:bookmaker": "tsx src/jobs/collect-bookmaker.ts",
    "sync:all": "tsx src/jobs/sync-all.ts",
    "sync:watch": "tsx src/jobs/sync-watch.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.105.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "got-scraping": "^4.2.1",
    "p-map": "^7.0.4",
    "pg": "^8.20.0",
    "playwright-core": "^1.60.0",
    "tough-cookie": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
