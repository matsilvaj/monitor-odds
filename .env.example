PORT=3333
NODE_ENV=development
CORS_ORIGINS=https://lzcommunity.com

# Supabase: preencha com os dados do seu projeto.
SUPABASE_DB_PASSWORD=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# API-Football / API-SPORTS.
API_FOOTBALL_KEY=
# Descoberta automatica de identidades (Wikidata/DuckDuckGo + Gemini gratuito).
# A chave fica somente na maquina coletora; nunca inclua o valor no GitHub ou no executavel.
TEAM_IDENTITY_RESOLVER_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
TEAM_IDENTITY_DAILY_LIMIT=400
TEAM_IDENTITY_MAX_ATTEMPTS=4
TEAM_IDENTITY_TIMEOUT_MS=20000
TEAM_IDENTITY_MAX_CONCURRENCY=2

# Monitor continuo: pausa entre ciclos e intervalo da limpeza global de jogos iniciados.
SYNC_WATCH_LOOP_PAUSE_MS=15000
SYNC_WATCH_CLEANUP_INTERVAL_MS=60000
GH_TOKEN=

# Browser collectors.
MERIDIANBET_BASE_URL=https://meridianbet.bet.br/
MERIDIANBET_CHROME_PROFILE_DIR=.browser/meridianbet-cdp-profile
MERIDIANBET_CHROME_EXECUTABLE=
MERIDIANBET_NAVIGATION_TIMEOUT_MS=45000
MERIDIANBET_MONITOR_TABS=5

BET365_BASE_URL=https://www.bet365.bet.br/
BET365_CHROME_PROFILE_DIR=.browser/bet365-profile
BET365_CHROME_EXECUTABLE=
BET365_NAVIGATION_WAIT_MS=12000
BET365_EVENT_WAIT_MS=6000
BET365_DEBUG_PORT=9223
BET365_MONITOR_TABS=5
BET365_ENABLED=true
BET365_COMPETITION_URL=
BET365_TARGET_LEAGUE_SLUGS=
BET365_FIXTURE_LIMIT_PER_LEAGUE=25
BET365_EVENT_TEXT_FILE=
