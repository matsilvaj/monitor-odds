PORT=3333
API_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=https://lzcommunity.com
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
PUBLIC_API_TOKEN=

# Supabase: preencha com os dados do seu projeto.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# API-Football / API-SPORTS.
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=
API_FOOTBALL_TIMEZONE=America/Bahia
API_FOOTBALL_FIXTURE_TTL_MINUTES=720

# Protege POST /internal/sync/all e rotas internas.
# Em producao, obrigatorio e com pelo menos 32 caracteres.
INTERNAL_COLLECT_TOKEN=

# Altenar connectors.
ALTENAR_BASE_URL=https://sb2frontend-altenar2.biahosted.com/api/

COLLECT_DELAY_MS=1500
LOG_RETENTION_DAYS=7

# bet365 usa Chrome real visivel com perfil persistente local.
BET365_BASE_URL=https://www.bet365.bet.br/
BET365_CHROME_PROFILE_DIR=.browser/bet365-cdp-profile
BET365_CHROME_EXECUTABLE=
BET365_MANUAL_FALLBACK=true
BET365_KEEP_BROWSER_OPEN=false
BET365_NAVIGATION_TIMEOUT_MS=45000

# Opcional: senha crua do banco para o npm run db:setup montar a SUPABASE_DB_URL.
SUPABASE_DB_PASSWORD=
